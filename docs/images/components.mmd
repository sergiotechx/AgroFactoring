    subgraph Blockchain[Capa Blockchain - Stellar]
        SC[Smart Contract Soroban<br/>Agro_Factoring.rs<br/>Escrow por fases]
        USDC[USDC Stellar Asset<br/>Testnet]
    end

    subgraph Oraculos[Capa Oraculos - Backend]
        WEATHER[API OpenWeatherMap<br/>+ IDEAM Colombia]
        SAT[API Sentinel Hub<br/>NDVI satelital]
        PHOTO[Evidencia Fotográfica<br/>Georeferenciada]
    end

    subgraph Datos[Capa Datos - Supabase]
        PG[(Postgres<br/>perfiles, cultivos,<br/>contratos, ledger,<br/>weather, iot)]
        AUTH[Auth jose JWT]
    end

    subgraph Fiat[Capa Fiat - Ultima Milla]
        TRANSAK[Transak Widget<br/>MVP Hackathon]
        BITSO[Bitso API<br/>Produccion v1]
        ANCHOR[Anchor SEP-24<br/>Escala]
    end

    subgraph Agricola[Capa Agricola]
        FARM[Finca Agricultor<br/>GPS lat/long]
    end

    FE -->|Soroban RPC + SDK 16| SC
    FE --> FW
